# PostgreSQL connection string. The included ../docker-compose.yml creates this database locally.
DATABASE_URL=postgresql://ethara_user:ethara_pass@localhost:5432/ethara_db

# Used only by the AI Assistant / NL query endpoint.
# Leave blank to fall back to the built-in rule-based parser (no key needed).
# Get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# CORS - comma separated list of allowed frontend origins
FRONTEND_ORIGINS=http://localhost:3000

# App
ENVIRONMENT=development